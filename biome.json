{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "experimentalScannerIgnores": [
      "**/dist/**",
      "**/src/generated/**",
      "**/storybook-static/**",
      ".turbo/**",
      "node_modules/**"
    ],
    "ignoreUnknown": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  }
}
