{
  "name": "@kusitms.com/icons",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@kusitms.com/tsconfig": "workspace:*",
    "@svgr/cli": "8.1.0",
    "@types/react": "19.2.14",
    "react": "19.2.4",
    "tsup": "8.5.1",
    "typescript": "6.0.2"
  },
  "scripts": {
    "build": "pnpm build:icons && tsup",
    "build:icons": "rm -rf src/generated && svgr --out-dir src/generated src/raw/icon src/raw/static && node scripts/strip-svg-prefix.mjs && node scripts/convert-icon-colors.mjs && biome check --write src/generated",
    "check": "pnpm build:icons && pnpm lint && pnpm typecheck",
    "lint": "biome check src scripts tsup.config.ts",
    "typecheck": "pnpm build:icons && tsc --project tsconfig.json"
  }
}
